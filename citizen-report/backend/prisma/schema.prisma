// Citizen Report — database schema.
// All access goes through Prisma (parameterized queries — no raw SQL on user input).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── Enums ─────────────────────────────

enum Role {
  CITIZEN
  MODERATOR
  ADMIN
}

enum ReportStatus {
  SUBMITTED // received, awaiting triage
  UNDER_REVIEW // an admin/moderator is reviewing
  INFO_REQUESTED // reviewer asked the reporter for more information
  APPROVED // reviewer judged the evidence credible -> forwarded for enforcement decision
  REJECTED // reviewer dismissed the report
  CLOSED // resolved / archived
}

enum MediaKind {
  IMAGE
  VIDEO
}

enum AuditAction {
  REPORT_CREATED
  REPORT_VIEWED
  EVIDENCE_VIEWED
  STATUS_CHANGED
  INFO_REQUESTED
  REPORT_APPROVED
  REPORT_REJECTED
  REPORT_CLOSED
  USER_ROLE_CHANGED
  DATA_EXPORTED
  DATA_ERASED
}

enum AiAnalysisType {
  PLATE_OCR
  FACE_BLUR
  TAMPER_DETECTION
  SUMMARY
}

// ───────────────────────────── Models ─────────────────────────────

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String
  displayName       String?
  role              Role      @default(CITIZEN)
  emailVerified     Boolean   @default(false)
  // Bumping this invalidates all previously issued access tokens.
  tokenVersion      Int       @default(0)
  verifyToken       String?   @unique
  verifyTokenExpiry DateTime?
  resetToken        String?   @unique
  resetTokenExpiry  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  reports       Report[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]     @relation("ActorAudit")

  @@index([role])
}

// Rotating refresh tokens. The raw token is never stored — only its hash.
model RefreshToken {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  // Tokens issued from the same login share a family; reuse detection revokes the family.
  family      String
  expiresAt   DateTime
  revokedAt   DateTime?
  // Set when this token is rotated, pointing at its successor (for reuse detection).
  replacedBy  String?
  createdByIp String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([family])
}

model Category {
  id          String   @id @default(uuid())
  slug        String   @unique // e.g. "illegal_parking"
  name        String // e.g. "Illegal parking"
  description String?
  active      Boolean  @default(true)
  reports     Report[]
  createdAt   DateTime @default(now())
}

model Report {
  id          String       @id @default(uuid())
  // Null when submitted anonymously.
  reporterId  String?
  reporter    User?        @relation(fields: [reporterId], references: [id], onDelete: SetNull)
  anonymous   Boolean      @default(false)
  // Optional encrypted contact for anonymous reporters who opt to be reachable.
  contactEnc  String?

  categoryId  String
  category    Category     @relation(fields: [categoryId], references: [id])

  status      ReportStatus @default(SUBMITTED)
  description String
  // AI-generated short summary (assistive only).
  summary     String?

  // Location.
  latitude    Float?
  longitude   Float?
  address     String?
  // When the incident occurred (may differ from submission time / EXIF derived).
  incidentAt  DateTime?

  // Privacy / moderation.
  consentGiven Boolean @default(false)
  // Note left for the reporter when status == INFO_REQUESTED.
  reviewerNote String?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  media       MediaAsset[]
  auditLogs   AuditLog[]
  aiAnalyses  AiAnalysis[]
  consent     ConsentRecord?

  @@index([status])
  @@index([categoryId])
  @@index([reporterId])
  @@index([createdAt])
  @@index([latitude, longitude])
}

model MediaAsset {
  id           String    @id @default(uuid())
  reportId     String
  report       Report    @relation(fields: [reportId], references: [id], onDelete: Cascade)
  kind         MediaKind
  // Object key in the private S3 bucket (random UUID, no original filename).
  storageKey   String    @unique
  // Key of the privacy-processed (face-blurred) derivative shown to reviewers.
  processedKey String?
  mimeType     String
  sizeBytes    Int
  width        Int?
  height       Int?
  // GPS extracted from EXIF, if present.
  exifLat      Float?
  exifLng      Float?
  exifTakenAt  DateTime?
  // SHA-256 of the original bytes (integrity / dedupe / tamper baseline).
  sha256       String?
  createdAt    DateTime  @default(now())

  @@index([reportId])
}

// Append-only audit trail of administrative actions.
model AuditLog {
  id         String      @id @default(uuid())
  action     AuditAction
  actorId    String?
  actor      User?       @relation("ActorAudit", fields: [actorId], references: [id], onDelete: SetNull)
  reportId   String?
  report     Report?     @relation(fields: [reportId], references: [id], onDelete: SetNull)
  // Structured before/after state and metadata.
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  @@index([reportId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

// Results of AI-assisted analysis. Advisory only — never an enforcement decision.
model AiAnalysis {
  id         String         @id @default(uuid())
  reportId   String
  report     Report         @relation(fields: [reportId], references: [id], onDelete: Cascade)
  mediaId    String?
  type       AiAnalysisType
  // e.g. { plate: "<encrypted>", confidence: 0.82 } | { tampered: false, score: 0.04 }
  result     Json
  confidence Float?
  provider   String?
  createdAt  DateTime       @default(now())

  @@index([reportId])
  @@index([type])
}

// Immutable record of the consent shown to and accepted by a reporter (GDPR).
model ConsentRecord {
  id            String   @id @default(uuid())
  reportId      String   @unique
  report        Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  policyVersion String
  consentText   String
  ip            String?
  userAgent     String?
  acceptedAt    DateTime @default(now())
}
