# ─────────────────────────────────────────────────────────────────────────────
# Backend environment. Copy to `.env`. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://citizen:change_me_postgres@localhost:5432/citizen_report?schema=public

# --- JWT ---
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# --- Field encryption (AES-256-GCM) ---
# 32-byte key in hex (64 chars): openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_char_hex_encryption_key

# --- Cookies ---
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# --- CORS ---
CORS_ORIGIN=http://localhost:3000

# --- S3 / MinIO ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=citizen-report-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change_me_minio
S3_FORCE_PATH_STYLE=true
SIGNED_URL_TTL_SECONDS=300

# --- Uploads ---
MAX_UPLOAD_MB=25
MAX_FILES_PER_REPORT=8

# --- Email (SMTP). If SMTP_HOST is empty, verification links are logged to stdout. ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Citizen Report <no-reply@citizen-report.example>"
APP_BASE_URL=http://localhost:3000

# --- CAPTCHA (hcaptcha | recaptcha | none) ---
CAPTCHA_PROVIDER=none
CAPTCHA_SECRET=

# --- Rate limiting (Redis recommended in prod; falls back to memory if unset) ---
REDIS_URL=

# --- Privacy / retention ---
DATA_RETENTION_DAYS=365

# --- Seed admin (used once by `npm run seed`) ---
SEED_ADMIN_EMAIL=admin@citizen-report.local
SEED_ADMIN_PASSWORD=ChangeMe!2024
