# ─────────────────────────────────────────────────────────────────────────────
# Backend environment. Copy to `.env`. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000

# --- Database (MongoDB) ---
MONGODB_URI=mongodb://localhost:27017/citizen_report

# --- JWT ---
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# --- Field encryption (AES-256-GCM) ---
# 32-byte key in hex (64 chars): openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_char_hex_encryption_key

# --- Cookies ---
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# --- CORS ---
CORS_ORIGIN=http://localhost:3000

# --- Cloudinary (private media storage) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Uploads ---
MAX_UPLOAD_MB=25
MAX_FILES_PER_REPORT=8

# --- Email (SMTP). If SMTP_HOST is empty, reset/verify links are logged to stdout. ---
# Gmail: create a 16-char App Password at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification), remove the spaces, and use it as SMTP_PASS.
# SMTP_USER and the From address must be the same Gmail account.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM="Reports <you@gmail.com>"
# Frontend base URL used to build reset/verify links in emails (prod: your deployed frontend URL).
APP_BASE_URL=http://localhost:3000

# --- CAPTCHA (hcaptcha | recaptcha | none) ---
CAPTCHA_PROVIDER=none
CAPTCHA_SECRET=

# --- Rate limiting (Redis recommended in prod; falls back to memory if unset) ---
REDIS_URL=

# --- Privacy / retention ---
DATA_RETENTION_DAYS=365

# --- Seed admin (used once by `npm run seed`) ---
SEED_ADMIN_EMAIL=admin@citizen-report.local
SEED_ADMIN_PASSWORD=ChangeMe!2024
