# ─────────────────────────────────────────────────────────────────────────────
# Root docker-compose environment.
# Copy to `.env` and replace every secret before deploying.
# ─────────────────────────────────────────────────────────────────────────────

# --- PostgreSQL ---
POSTGRES_USER=citizen
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=citizen_report
POSTGRES_PORT=5432

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=citizen-report-media

# --- Backend ---
BACKEND_PORT=4000
# 32+ char random strings. Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
# AES-256 key (32 bytes hex = 64 chars) for field encryption: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_char_hex_encryption_key

# --- Frontend ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
